# =============================================================================
# chain-indexer — copy to .env next to this file.
# Shared infra (Postgres, Redis, Docker): see repo root .env.example
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=odl
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_POOL_MAX=10

REDIS_URI=redis://localhost:6379

START_BLOCK_NUMBER=102138605
HANDLER_CUSTOM_JSON_ENABLED=true

# Hive RPC client / URL rotation (optional; lib defaults used if unset)
# HIVE_CACHE_PREFIX=hive_client_url_rotation
# HIVE_CACHE_TTL_SECONDS=1200
# HIVE_MAX_RESPONSE_TIME_MS=8000
# HIVE_URL_ROTATION_DB=0
# ODL_NETWORK=mainnet

IPFS_API_URL=http://localhost:5001
# IPFS_GATEWAY_URL=http://localhost:8080

# IPFS fetch + batch import retries
# BATCH_IMPORT_MAX_RETRIES=3
# BATCH_IMPORT_RETRY_DELAY_MS=1000
