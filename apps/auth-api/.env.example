# =============================================================================
# auth-api — copy to `apps/auth-api/.env` (gitignored).
#
# Full stack `docker compose` overrides POSTGRES_*/REDIS_*/PORT for the Docker
# network — see repo root `.env.example`. This file targets local `nx serve`.
# HiveSigner defaults are also baked into env.validation.ts (no secret required).
# =============================================================================
PORT=7100
JWT_SECRET=change-me-min-16-chars-for-dev
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_APP_DISPLAY_ORIGIN=http://localhost:3000
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=odl
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
HIVE_RPC_NODES=https://api.hive.blog
CHALLENGE_TTL_SECONDS=300
# HiveSigner OAuth (implicit flow — HIVESIGNER_CLIENT_SECRET not required)
HIVESIGNER_APP_NAME=www.waivio.com
HIVESIGNER_CLIENT_SECRET=
HIVESIGNER_CALLBACK_URL=http://localhost:3000/api/auth/callback/hivesigner
HIVESIGNER_SCOPE=login,vote,comment,delete_comment,custom_json,follow,reblog,claim_reward_balance,transfer,transfer_to_vesting,withdraw_vesting,account_update,account_update2,convert,limit_order_create,limit_order_cancel
HIVESIGNER_API_URL=https://hivesigner.com
