# Copy to apps/auth-api/.env (gitignored). Same Postgres DB as chain/query after ODL migrations (00001_odl_schema).
PORT=7100
JWT_SECRET=change-me-min-16-chars-for-dev
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_APP_DISPLAY_ORIGIN=https://localhost:3000
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=odl
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
HIVE_RPC_NODES=https://api.hive.blog
CHALLENGE_TTL_SECONDS=300
# HiveSigner OAuth (optional)
HIVESIGNER_APP_NAME=
HIVESIGNER_CLIENT_SECRET=
HIVESIGNER_CALLBACK_URL=
HIVESIGNER_SCOPE=login
HIVESIGNER_API_URL=https://hivesigner.com
