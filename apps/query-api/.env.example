# =============================================================================
# query-api — copy to .env next to this file.
# Shared infra (Postgres, Docker): see repo root .env.example
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=odl
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_POOL_MAX=10

REDIS_URI=redis://localhost:6379

# HTTP listen port (Nest uses PORT; default 3000)
PORT=7000
