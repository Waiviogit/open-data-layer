# =============================================================================
# notifications — copy to `apps/notifications/.env` (gitignored).
# JWT must match auth-api when verifying access tokens.
#
# Full stack `docker compose` overrides PORT/JWT_SECRET — see repo root `.env.example`.
# =============================================================================
PORT=7200
JWT_SECRET=change-me-min-16-chars-for-dev
REDIS_URI=redis://localhost:6379
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=odl
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_POOL_MAX=10
SUBSCRIPTION_TTL_SECONDS=300
WS_PING_INTERVAL_MS=30000
WS_PING_TIMEOUT_MS=10000
WS_MAX_CONNECTIONS_PER_USER=5
