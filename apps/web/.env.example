# =============================================================================
# web (Next.js) — copy to .env next to this file.
# Next.js also reads .env.local, .env.development, etc. from apps/web/.
# Shared workspace defaults: see repo root .env.example
# =============================================================================

# Server-side base URL for query-api (Server Components only; no NEXT_PUBLIC_)
QUERY_API_URL=http://localhost:7000

# Optional: server-side theme sync endpoint
# WEB_THEME_SYNC_URL=
