# =============================================================================
# web (Next.js) — copy to `.env` next to this file.
# Next.js also reads `.env.local`, `.env.development`, etc. from `apps/web/`.
#
# Local dev: `localhost` below. Full stack `docker compose` overrides server-side
# URLs for the Docker network — see repo root `.env.example`.
# =============================================================================

# Server-side origin for query-api (no path; code calls /query/v1/... — no NEXT_PUBLIC_)
QUERY_API_URL=http://localhost:3000

# auth-api origin (no path; BFF proxies to /auth/v1/... under /api/auth/*)
AUTH_API_BASE_URL=http://localhost:7100

# Must match auth-api JWT_SECRET (server-only; verifies httpOnly session cookie)
AUTH_JWT_SECRET=

# Optional: server-side theme sync endpoint
# WEB_THEME_SYNC_URL=

# Hive json_metadata defaults (client + server; embedded at build time)
# NEXT_PUBLIC_HIVE_JSON_COMMUNITY=opden
# NEXT_PUBLIC_HIVE_JSON_APP=opden/1.0.0
