{
  "name": "chain-indexer-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "implicitDependencies": ["chain-indexer"],
  "projectType": "application",
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/chain-indexer-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["chain-indexer:build", "chain-indexer:serve"]
    }
  }
}
