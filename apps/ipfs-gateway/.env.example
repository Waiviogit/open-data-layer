# =============================================================================
# ipfs-gateway — copy to `.env` next to this file.
#
# Local `nx serve`: `localhost` IPFS API below. Full stack `docker compose`
# overrides IPFS_API_URL/PORT — see repo root `.env.example`.
# =============================================================================
PORT=7300

# Must match auth-api / query-api JWT_SECRET
JWT_SECRET=

IPFS_API_URL=http://localhost:5001
# Optional: public gateway base for returned URLs (e.g. http://localhost:8080)
# IPFS_GATEWAY_URL=http://localhost:8080

# Comma-separated peer ipfs-gateway base URLs (e.g. http://host:7300/ipfs-gateway)
# IPFS_PEER_URLS=

# PIN_SYNC_INTERVAL_MS=300000
