# =============================================================================
# Workspace .env for docker compose + optional Nx. Copy to `.env` and adjust.
#
# All variables below are optional for compose: every key has a default in the
# compose files (see root `docker-compose.yml`, which includes `docker-compose.infra.yml`).
# For production, change JWT_SECRET and POSTGRES_PASSWORD.
#
# VPS repo install path (must match `INSTALL_DIR` in setup-vps when using Portainer stacks from disk)
# -----------------------------------------------------------------------------
INSTALL_DIR=/opt/open-data-layer

# -----------------------------------------------------------------------------
# stack-watchdog (optional — VPS compose enables it on the stack-watchdog service)
# Matches docker-compose.<DEPLOY_ENV>.apps.yml on this host; setup-vps appends DEPLOY_ENV when missing.
# On laptop development keep STACK_WATCHDOG_ENABLED unset or false (omit DEPLOY_ENV unless testing sync).
# -----------------------------------------------------------------------------
# DEPLOY_ENV=staging
# STACK_WATCHDOG_ENABLED=false

# Docker stack expects Docker network hostnames (postgres, redis, ipfs, …).
# For `pnpm nx serve <app>` on the host, use per-app `.env` under apps/* with
# localhost — see each app's `.env.example`.
# =============================================================================
NX_LOAD_DOT_ENV_FILES=true

# -----------------------------------------------------------------------------
# Public entry (only published port)
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80

# -----------------------------------------------------------------------------
# SSL — required for staging/production (jonasal/nginx-certbot)
# Set DOMAIN to your real domain and CERTBOT_EMAIL to a valid address.
# On first `docker compose up`, certbot will request a certificate from Let's Encrypt.
# -----------------------------------------------------------------------------
DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# PostgreSQL (postgis/postgis image + apps)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=odl
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_POOL_MAX=10

# -----------------------------------------------------------------------------
# Redis + IPFS (internal URLs — use service names)
# -----------------------------------------------------------------------------
REDIS_URI=redis://redis:6379
IPFS_API_URL=http://ipfs:5001

# -----------------------------------------------------------------------------
# Internal HTTP listen ports (not published to host; used inside the network)
# -----------------------------------------------------------------------------
QUERY_API_PORT=7000
AUTH_API_PORT=7100
NOTIFICATIONS_PORT=7200
IPFS_GATEWAY_APP_PORT=7300
WEB_PORT=3000

# -----------------------------------------------------------------------------
# Auth (query-api, auth-api, notifications, web AUTH_JWT_SECRET)
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-min-16-chars-for-dev
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Web (Next.js server-side fetches over Docker network)
# -----------------------------------------------------------------------------
QUERY_API_URL=http://query-api:7000
AUTH_API_BASE_URL=http://auth-api:7100

# -----------------------------------------------------------------------------
# Currency feeds (scheduler job `currency-*`, query-api `/query/v1/currency/*`)
# Optional. CoinGecko: use `COINGECKO_API_BASE_URL=https://pro-api.coingecko.com/api/v3` for Pro.
# -----------------------------------------------------------------------------
# COINGECKO_API_KEY=
# EXCHANGE_RATE_ACCESS_KEY=

# -----------------------------------------------------------------------------
# ODL Hive custom_json network (web + chain-indexer on the same stack)
# testnet → id odl-testnet; mainnet → odl-mainnet. One value for all app containers.
# -----------------------------------------------------------------------------
# ODL_NETWORK=testnet

# -----------------------------------------------------------------------------
# chain-indexer
# Hive parser start block: block number from which the Hive chain parser begins indexing.
# Hive Engine parser start block: block number for the Hive Engine (sidechain) parser.
# Set to a recent block to skip historical data on a fresh VPS.
# -----------------------------------------------------------------------------
START_BLOCK_NUMBER=102138605
HIVE_ENGINE_START_BLOCK=59083591
HANDLER_CUSTOM_JSON_ENABLED=true
