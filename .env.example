# =============================================================================
# PostgreSQL + PostGIS (postgis/postgis image)
# Used by: docker-compose postgres service, chain-indexer, query-api
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=odl
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_POOL_MAX=10

# =============================================================================
# Redis
# Used by: docker-compose redis service, chain-indexer
# =============================================================================
REDIS_URI=redis://localhost:6379
REDIS_PORT=6379

# =============================================================================
# chain-indexer
# =============================================================================
POSTGRES_DATABASE=odl
START_BLOCK_NUMBER=102138605
BLOCK_NUMBER_KEY=chain_indexer:block_number
HANDLER_CUSTOM_JSON_ENABLED=true

# Hive RPC client / URL rotation (optional; lib defaults used if unset)
# HIVE_CACHE_PREFIX=hive_client_url_rotation
# HIVE_CACHE_TTL_SECONDS=1200
# HIVE_MAX_RESPONSE_TIME_MS=8000
# HIVE_URL_ROTATION_DB=0

# =============================================================================
# query-api
# =============================================================================
QUERY_API_PORT=3000

# =============================================================================
# Legacy / migrations (DATABASE_URL must match Postgres settings above)
# =============================================================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/odl
