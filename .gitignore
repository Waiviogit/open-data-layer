# Generated by setup-vps.sh or: htpasswd -bc nginx/.htpasswd admin
nginx/.htpasswd

# Generated by jonasal/nginx-certbot at runtime or setup-vps.sh
# Keep: *.conf.template, 00-acme.conf (static). Ignore: generated default.conf and .nokey files.
nginx/conf.d/default.conf
nginx/conf.d/*.nokey